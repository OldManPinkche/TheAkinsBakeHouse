# The Akins Bake House local environment template
# Copy these values into .env and into Netlify environment variables.

SQUARE_ACCESS_TOKEN=paste_square_access_token_here
SQUARE_LOCATION_ID=auto
SQUARE_ENVIRONMENT=production
SITE_URL=https://theakinsbakehouse.com

SQUARE_WEBHOOK_URL=https://theakinsbakehouse.com/api/square-payment-webhook
SQUARE_WEBHOOK_SIGNATURE_KEY=paste_square_webhook_signature_key_here

# Free order notifications through a private Discord channel.
DISCORD_ORDER_WEBHOOK_URL=paste_discord_webhook_url_here
